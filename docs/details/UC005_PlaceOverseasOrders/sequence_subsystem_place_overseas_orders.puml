@startuml sequence_subsystem_place_overseas_orders
title Subsystem Sequence Diagram - OrderTransmissionSubsystem (PlaceOverseasOrders)

participant "OverseasOrderingController" as Client
box "OrderTransmissionSubsystem" #LightBlue
  participant "OrderTransmissionFacade" as Facade <<subsystem>>
  participant "XMLGeneratorService" as XMLGen <<service>>
  participant "SFTPUploadService" as SFTP <<service>>
end box

Client -> Facade : transmitOrder(siteCode, orderDetails)
activate Facade

Facade -> XMLGen : generateOrderXML(orderDetails)
activate XMLGen
XMLGen --> Facade : xmlDocument
deactivate XMLGen

Facade -> SFTP : uploadToSiteServer(siteCode, xmlDocument)
activate SFTP
SFTP --> Facade : sftpSuccess
deactivate SFTP

Facade --> Client : transmissionResult(sftpSuccess)
deactivate Facade
@enduml
