@startuml sequence_analysis_place_overseas_orders
title Analysis Sequence Diagram - PlaceOverseasOrders

actor InternationalOrderingDepartment as Actor
boundary "Boundary:OverseasOrderingUI" as Boundary
control "Control:OverseasOrderingController" as Control
entity "Entity:OverseasOrder" as Entity
actor OverseasImportSite as SiteActor

Actor -> Boundary : triggerOrderGeneration(planId)
activate Boundary
Boundary -> Control : generateOrders(planId)
activate Control

Control -> Entity : composeOrdersFromPlan(planId)
activate Entity
Entity --> Control : ordersList
deactivate Entity

loop for each order in ordersList
  Control -> SiteActor : transmitOrder(order.siteCode, order.details)
  activate SiteActor
  SiteActor --> Control : returnAcknowledgement(ackToken)
  deactivate SiteActor
  
  Control -> Entity : setOrderStatus(order.orderId, "Transmitted", ackToken)
  activate Entity
  Entity --> Control : orderUpdated
  deactivate Entity
end

Control --> Boundary : ordersPlacedSuccessfully()
deactivate Control
Boundary --> Actor : showSuccessMessage()
deactivate Boundary
@enduml

