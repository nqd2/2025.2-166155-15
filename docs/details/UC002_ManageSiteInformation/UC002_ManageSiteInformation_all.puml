@startuml sequence_analysis_manage_site_information
title Analysis Sequence Diagram - ManageSiteInformation

actor OverseasImportSite as Actor
participant "SiteInformationUI" as Boundary <<boundary>>
participant "SiteInformationController" as Control <<control>>
entity "ImportSite" as Entity <<entity>>
actor InternationalOrderingDepartment as OrderingDept

Actor -> Boundary : selectSiteProfile(siteCode)
activate Boundary
Boundary -> Control : getSiteDetails(siteCode)
activate Control
Control -> Entity : findByCode(siteCode)
activate Entity
Entity --> Control : siteDetails
deactivate Entity
Control --> Boundary : displaySiteDetails(siteDetails)
deactivate Control
Boundary --> Actor : showProfileForm()
deactivate Boundary

Actor -> Boundary : updateSiteData(profileData)
activate Boundary
Boundary -> Control : updateProfile(siteCode, profileData)
activate Control

alt Validation Success
  Control -> Entity : saveProfile(profileData)
  activate Entity
  Entity --> Control : saveSuccess
  deactivate Entity
  Control --> OrderingDept : notifyOrderingDepartmentOfSiteChanges(siteCode)
  Control --> Boundary : success()
  Boundary --> Actor : showSuccessMessage()
else Validation Failure
  Control --> Boundary : failure(errors)
  deactivate Control
  Boundary --> Actor : showErrorMessage(errors)
  deactivate Boundary
end
@enduml

