@startuml class_analysis_manage_site_information
skinparam BackgroundColor #FFFFFF
skinparam RoundCorner 8
skinparam DefaultFontName "Helvetica"
skinparam DefaultFontSize 12
skinparam ClassBorderColor #37474F
skinparam ClassBackgroundColor #ECEFF1
skinparam ClassHeaderBackgroundColor #CFD8DC
skinparam ClassAttributeIconSize 0

title Class Diagram (Analysis Level) - ManageSiteInformation

class SiteInformationUI <<boundary>> {
  +displaySiteDetails(siteDetails: Object)
  +showProfileForm()
  +getUpdatedProfileData(): Object
  +showSuccessMessage()
  +showErrorMessage(errors: List)
}

class SiteInformationController <<control>> {
  +getSiteDetails(siteCode: String)
  +updateProfile(siteCode: String, data: Object)
  -validateSiteData(data: Object): boolean
}

class ImportSite <<entity>> {
  -siteCode: String
  -siteName: String
  -deliveryDaysByShip: int
  -deliveryDaysByAir: int
  -otherInformation: String
  -merchandiseCatalog: List<Merchandise>
  +findByCode(siteCode: String): ImportSite
  +saveProfile(data: Object)
}

class Merchandise <<entity>> {
  -merchandiseCode: String
}

SiteInformationUI --> SiteInformationController
SiteInformationController --> ImportSite
ImportSite "1" *-- "*" Merchandise
@enduml
