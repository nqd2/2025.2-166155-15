@startuml sequence_subsystem_manage_site_information
title Subsystem Sequence Diagram - SiteCatalogSubsystem (ManageSiteInformation)

participant "SiteInformationController" as Client
box "SiteCatalogSubsystem" #LightBlue
  participant "Facade:SiteCatalogFacade" as Facade
  participant "Catalog:ProductCatalogService" as Catalog
  participant "Notify:NotificationService" as Notify
end box

Client -> Facade : updateCatalog(siteCode, catalogData)
activate Facade

Facade -> Catalog : validateProducts(catalogData)
activate Catalog
Catalog --> Facade : validationResult
deactivate Catalog

Facade -> Notify : triggerSiteChangeNotification(siteCode)
activate Notify
Notify --> Facade : notificationSent
deactivate Notify

Facade --> Client : updateResult(success)
deactivate Facade
@enduml
