@startuml sequence_subsystem_collect_inventory_data
title Subsystem Sequence Diagram - StockQuerySubsystem (CollectInventoryData)

participant "InventoryCollectionController" as Client
box "StockQuerySubsystem" #LightBlue
  participant "Facade:StockQueryFacade" as Facade
  participant "Service:StockQueryService" as Service
  participant "Connection:APIConnectionPool" as Connection
end box

Client -> Facade : queryStock(siteCode, items)
activate Facade

Facade -> Service : dispatchStockQuery(siteCode, items)
activate Service

Service -> Connection : getConnection(siteCode)
activate Connection
Connection --> Service : connectionInstance
deactivate Connection

Service -> Service : sendRequestViaAPI(connectionInstance, items)
Service --> Facade : apiResponse(stockData)
deactivate Service

Facade --> Client : queryResult(stockData)
deactivate Facade
@enduml
