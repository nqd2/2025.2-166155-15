@startuml sequence_subsystem_manage_system
title Subsystem Sequence Diagram - SecuritySubsystem (ManageSystem)

participant "SystemAdminController" as Client
box "SecuritySubsystem" #LightBlue
  participant "Facade:SecurityFacade" as Facade
  participant "RBAC:RBACAuthorizationService" as RBAC
  participant "Session:UserSessionManager" as Session
end box

Client -> Facade : checkPermission(operatorId, requiredPermission)
activate Facade

Facade -> Session : getActiveSession(operatorId)
activate Session
Session --> Facade : sessionDetails
deactivate Session

Facade -> RBAC : verifyAccess(sessionDetails.role, requiredPermission)
activate RBAC
RBAC --> Facade : accessGranted
deactivate RBAC

Facade --> Client : authorizationResult(accessGranted)
deactivate Facade
@enduml
