@startuml class_analysis_manage_import_requests
skinparam BackgroundColor #FFFFFF
skinparam RoundCorner 8
skinparam DefaultFontName "Helvetica"
skinparam DefaultFontSize 12
skinparam ClassBorderColor #37474F
skinparam ClassBackgroundColor #ECEFF1
skinparam ClassHeaderBackgroundColor #CFD8DC
skinparam ClassAttributeIconSize 0

title Class Diagram (Analysis Level) - ManageImportRequests

class ImportRequestUI <<boundary>> {
  +displayForm()
  +getInputData()
  +showSuccessMessage(requestId)
  +showErrorMessage(errors)
}

class ImportRequestController <<control>> {
  +validateAndProcessRequest(data)
  -checkValidationRules(data)
}

class ImportRequest <<entity>> {
  -requestId: String
  -status: String
  -createdDate: Date
  +create(data)
  +updateStatus(status)
}

class Merchandise <<entity>> {
  -merchandiseCode: String
  -quantityOrdered: int
  -unit: String
  -desiredDeliveryDate: Date
  +checkExistence(merchandiseCode)
}

ImportRequestUI --> ImportRequestController
ImportRequestController --> ImportRequest
ImportRequestController --> Merchandise
ImportRequest "1" *-- "*" Merchandise
@enduml
