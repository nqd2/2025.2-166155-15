@startuml sequence_subsystem_manage_import_requests
title Subsystem Sequence Diagram - ValidationSubsystem (ManageImportRequests)

participant "ImportRequestController" as Client
box "ValidationSubsystem" #LightBlue
  participant "Facade:ValidationFacade" as Facade
  participant "Catalog:CatalogValidator" as Catalog
  participant "Qty:QuantityValidator" as Qty
  participant "DateVal:DateValidator" as DateVal
end box

Client -> Facade : validateRequest(data)
activate Facade

Facade -> Catalog : checkExistence(merchandiseCode)
activate Catalog
Catalog --> Facade : exists
deactivate Catalog

Facade -> Qty : validatePositive(quantityOrdered)
activate Qty
Qty --> Facade : isValidQty
deactivate Qty

Facade -> DateVal : validateFutureDate(desiredDeliveryDate)
activate DateVal
DateVal --> Facade : isValidDate
deactivate DateVal

Facade --> Client : validationResult(errors)
deactivate Facade
@enduml
