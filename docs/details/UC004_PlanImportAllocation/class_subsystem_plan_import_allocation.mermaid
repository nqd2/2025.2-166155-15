classDiagram
  class AllocationFacade {
    <<facade>>
    +calculateAllocation(requestId String, records List, sites List) List
  }

  class FeasibilityChecker {
    <<service>>
    +checkDeliveryFeasibility(records List, sites List) List
  }

  class SiteRanker {
    <<service>>
    +rankSites(sites List) List
  }

  class SplitCalculator {
    <<service>>
    +splitQuantity(requestId String, rankedSites List) List
  }

  AllocationFacade --> FeasibilityChecker
  AllocationFacade --> SiteRanker
  AllocationFacade --> SplitCalculator
