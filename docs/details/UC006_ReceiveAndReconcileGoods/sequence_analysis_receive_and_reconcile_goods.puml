@startuml sequence_analysis_receive_and_reconcile_goods
title Analysis Sequence Diagram - ReceiveAndReconcileGoods

actor WarehouseManagementDepartment as Actor
participant "GoodsReceiptUI" as Boundary <<boundary>>
participant "GoodsReceiptController" as Control <<control>>
entity "OverseasOrder" as Order <<entity>>
entity "GoodsReceipt" as Entity <<entity>>
entity "WarehouseStock" as Stock <<entity>>

Actor -> Boundary : selectOrderToReceive(orderId)
activate Boundary
Boundary -> Control : getExpectedOrderDetails(orderId)
activate Control
Control -> Order : findById(orderId)
activate Order
Order --> Control : orderDetails
deactivate Order
Control --> Boundary : showReconciliationForm(orderDetails)
deactivate Control
Boundary --> Actor : displayExpectedQuantities()
deactivate Boundary

Actor -> Boundary : submitReceiptDetails(receivedQuantities)
activate Boundary
Boundary -> Control : processReceipt(orderId, receivedQuantities)
activate Control

Control -> Control : compareAndDetectDiscrepancies(orderDetails, receivedQuantities)

Control -> Entity : createReceipt(orderId, receivedQuantities, discrepancies)
activate Entity
Entity --> Control : receiptInstance
deactivate Entity

Control -> Stock : updateStockLevels(receivedQuantities)
activate Stock
Stock --> Control : stockUpdated
deactivate Stock

Control --> Boundary : receiptSuccessfullyProcessed(receiptInstance)
deactivate Control
Boundary --> Actor : showReceiptSummary(receiptInstance)
deactivate Boundary
@enduml
