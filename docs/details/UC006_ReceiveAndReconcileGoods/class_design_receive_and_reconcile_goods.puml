@startuml class_design_receive_and_reconcile_goods
skinparam BackgroundColor #FFFFFF
skinparam RoundCorner 8
skinparam DefaultFontName "Helvetica"
skinparam DefaultFontSize 12
skinparam ClassBorderColor #37474F
skinparam ClassBackgroundColor #ECEFF1
skinparam ClassHeaderBackgroundColor #CFD8DC
skinparam ClassAttributeIconSize 0

title Class Diagram (Design Level) - ReceiveAndReconcileGoods

class GoodsReceiptUI {
  +displayExpectedQuantities(): void
  +showReconciliationForm(order: Object): void
  +showReceiptSummary(receipt: GoodsReceipt): void
}

class GoodsReceiptController {
  -reconciliationFacade: ReconciliationFacade
  -orderRepo: OverseasOrderRepository
  -receiptRepo: GoodsReceiptRepository
  -stockRepo: WarehouseStockRepository
  +getExpectedOrderDetails(orderId: String): void
  +processReceipt(orderId: String, received: List<Map>): void
}

class OverseasOrder {
  -orderId: String
  -siteCode: String
  -status: String
  -orderLines: List<Object>
  +getOrderId(): String
  +getOrderLines(): List<Object>
}

class GoodsReceipt {
  -receiptId: String
  -orderId: String
  -receivedDate: Date
  -receiptLines: List<ReceiptLine>
  +GoodsReceipt(orderId: String, lines: List<ReceiptLine>)
  +getReceiptId(): String
  +getOrderId(): String
  +getReceiptLines(): List<ReceiptLine>
}

class ReceiptLine {
  -merchandiseCode: String
  -receivedQty: int
  -discrepancyQty: int
  -discrepancyType: String
  +getMerchandiseCode(): String
  +getReceivedQty(): int
  +getDiscrepancyQty(): int
  +getDiscrepancyType(): String
}

class WarehouseStock {
  -merchandiseCode: String
  -quantityInStock: int
  +WarehouseStock(merchandiseCode: String, quantityInStock: int)
  +getMerchandiseCode(): String
  +getQuantityInStock(): int
  +addQuantity(qty: int): void
}

class OverseasOrderRepository {
  -dbConnection: Object
  +findById(orderId: String): OverseasOrder
}

class GoodsReceiptRepository {
  -dbConnection: Object
  +save(receipt: GoodsReceipt): GoodsReceipt
}

class WarehouseStockRepository {
  -dbConnection: Object
  +findByCode(code: String): WarehouseStock
  +save(stock: WarehouseStock): boolean
}

class ReconciliationFacade {
  -calculator: Object
  -reporter: Object
  +reconcile(expected: List, received: List): ReconciliationResult
}

GoodsReceiptUI --> GoodsReceiptController
GoodsReceiptController --> ReconciliationFacade
GoodsReceiptController --> OverseasOrderRepository
GoodsReceiptController --> GoodsReceiptRepository
GoodsReceiptController --> WarehouseStockRepository
OverseasOrderRepository --> OverseasOrder
GoodsReceiptRepository --> GoodsReceipt
GoodsReceipt "1" *-- "*" ReceiptLine
WarehouseStockRepository --> WarehouseStock
@enduml
