@startuml sequence_subsystem_receive_and_reconcile_goods
title Subsystem Sequence Diagram - ReconciliationSubsystem (ReceiveAndReconcileGoods)

participant "GoodsReceiptController" as Client
box "ReconciliationSubsystem" #LightBlue
  participant "Facade:ReconciliationFacade" as Facade
  participant "Calculator:DiscrepancyCalculator" as Calculator
  participant "Reporter:ReconciliationReportService" as Reporter
end box

Client -> Facade : reconcile(expectedItems, receivedItems)
activate Facade

Facade -> Calculator : compareQuantities(expectedItems, receivedItems)
activate Calculator
Calculator --> Facade : discrepancyDetails
deactivate Calculator

Facade -> Reporter : generateReport(discrepancyDetails)
activate Reporter
Reporter --> Facade : reportDocument
deactivate Reporter

Facade --> Client : reconciliationResult(discrepancyDetails, reportDocument)
deactivate Facade
@enduml
